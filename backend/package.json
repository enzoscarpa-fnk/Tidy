{
  "name": "@tidy/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --build",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "dev:db": "docker compose -f ../docker-compose.yml up -d",
    "dev:db:stop": "docker compose -f ../docker-compose.yml down",
    "dev:db:logs": "docker compose -f ../docker-compose.yml logs -f postgres"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "pino-pretty": "^11.2.0",
    "prisma": "^6.5.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.3"
  }
}
