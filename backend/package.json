{
  "name": "@tidy/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --build",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "dev:db": "docker compose -f ../docker-compose.yml up -d",
    "dev:db:stop": "docker compose -f ../docker-compose.yml down",
    "dev:db:logs": "docker compose -f ../docker-compose.yml logs -f postgres",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcrypt": "^6.0.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^5.0.1",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^2.1.9",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.5.0",
    "supertest": "^7.2.2",
    "tsx": "^4.16.0",
    "typescript": "^5.5.3",
    "vitest": "^2.1.9"
  }
}
