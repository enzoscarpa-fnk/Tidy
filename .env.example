# ── Serveur ────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ── Base de données ────────────────────────────────────────────────────────
# Format : postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL="postgresql://tidy:tidy_dev_password@localhost:5432/tidy_db"
POSTGRES_USER=tidy
POSTGRES_PASSWORD=tidy_dev_password
POSTGRES_DB=tidy_db
POSTGRES_PORT=5432

# ── Auth JWT ───────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_with_a_64_bytes_random_hex_string
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# ── AWS S3 ─────────────────────────────────────────
AWS_BUCKET=tidy-documents-dev
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_ENDPOINT_URL=        # optionnel : LocalStack / MinIO en dev local

# ── Mistral OCR ────────────────────────────────────
MISTRAL_API_KEY=your-mistral-api-key
