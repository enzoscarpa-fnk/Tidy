# ── Serveur ────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ── Base de données ────────────────────────────────────────────────────────
# Format : postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL="postgresql://tidy:tidy_dev_password@localhost:5432/tidy_db"
POSTGRES_USER=tidy
POSTGRES_PASSWORD=tidy_dev_password
POSTGRES_DB=tidy_db
POSTGRES_PORT=5432

# ── Auth JWT ───────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_with_a_64_bytes_random_hex_string
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# ── AWS S3 (rempli en Ticket 4.4) ─────────────────────────────────────────
AWS_BUCKET=
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Mistral OCR (rempli en Ticket 4.5) ────────────────────────────────────
MISTRAL_API_KEY=
